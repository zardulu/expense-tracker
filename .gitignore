.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/

# Env files (never commit secrets)
**/.env
**/.env.*
!**/.env.example

# SQLite artifacts
**/*.db
**/*.db-journal
**/*.sqlite
**/*.sqlite3

# Expo / React Native
**/.expo/
**/.expo-shared/
**/web-build/
**/coverage/

# TypeScript
**/*.tsbuildinfo

# IDE
.vscode/
.idea/
